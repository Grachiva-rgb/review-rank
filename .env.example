# -----------------------------------------------
# ReviewRank — Environment Variables
# -----------------------------------------------
# Copy this file to .env.local and fill in values.
# Never commit .env.local to version control.

# -----------------------------------------------
# Required — Google Places API
# -----------------------------------------------
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create a new API key
# 3. Enable: "Places API" under APIs & Services > Library
# 4. (Recommended) Restrict the key to your server's IP or domain
GOOGLE_PLACES_API_KEY=

# -----------------------------------------------
# Required — Site URL (used for Stripe callbacks and OG metadata)
# -----------------------------------------------
# No trailing slash. Must match the deployed domain exactly.
NEXT_PUBLIC_SITE_URL=https://reviewrank.app

# -----------------------------------------------
# Required — Admin Access
# -----------------------------------------------
# Protects /admin/* routes via HTTP Basic Auth.
# Choose a long random string (e.g. openssl rand -hex 32).
ADMIN_SECRET=

# -----------------------------------------------
# Supabase (required for leads, partners, report requests)
# -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------
# Stripe (required for partner subscription checkout)
# -----------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------
# Resend (required for lead delivery emails to partners)
# -----------------------------------------------
RESEND_API_KEY=re_...
# The "from" address for emails sent to partners (must be a verified Resend sender)
RESEND_FROM_ADDRESS=leads@reviewrank.app

# -----------------------------------------------
# PostHog Analytics (optional — client-side only)
# -----------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------
# Tripadvisor Content API (optional — enables multi-source scoring for
# restaurants, hotels, attractions, and resorts)
# -----------------------------------------------
# 1. Apply for access: https://developer-tripadvisor.com/content-api/
# 2. Paste your key below. This is SERVER-SIDE ONLY — never use NEXT_PUBLIC_.
# 3. Run the Supabase migration: supabase/migrations/001_tripadvisor_integration.sql
# 4. Trigger ingestion: POST /api/admin/ingest-tripadvisor
#    Authorization: Bearer <ADMIN_SECRET>
#    Body: {} (refreshes all stale records) or {"placeId": "ChIJ..."}
TRIPADVISOR_API_KEY=

# -----------------------------------------------
# Vercel Cron Secret (auto-set by Vercel for cron jobs)
# -----------------------------------------------
# Vercel automatically sets CRON_SECRET for cron job authentication.
# You do not need to set this manually — Vercel injects it at deploy time.
# CRON_SECRET=
